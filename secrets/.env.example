# Application Environment
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3000

# Database Configuration
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=budget_app
DB_USER=budget_user
# DB_PASSWORD is loaded from secrets/*/db_password.txt

# JWT Configuration
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
# JWT_SECRET is loaded from secrets/*/jwt_secret.txt

# Encryption Configuration
ENCRYPTION_ALGORITHM=aes-256-gcm
# ENCRYPTION_KEY is loaded from secrets/*/encryption_key.txt
# PASSWORD_PEPPER is loaded from secrets/*/password_pepper.txt

# SimpleFIN Configuration
SIMPLEFIN_API_URL=https://bridge.simplefin.org
# SIMPLEFIN_TOKEN is loaded from secrets/*/simplefin_token.txt

# Security Configuration
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=/app/logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/uploads

# WebAuthn Configuration
WEBAUTHN_RP_NAME=Budget App
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Frontend Configuration (for build-time injection)
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ENABLE_OFFLINE=true
REACT_APP_CACHE_DURATION=86400000
